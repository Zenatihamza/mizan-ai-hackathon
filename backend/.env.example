# Copy this file to .env and fill in values

# LLM backend: "ollama" or "mock"
# mock = no model needed, returns canned demo responses (safe for stage)
# ollama = real local LLM via http://localhost:11434
LLM_BACKEND=mock

# Ollama settings (only used if LLM_BACKEND=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Path to Tesseract executable on Windows (install from https://github.com/UB-Mannheim/tesseract/wiki)
# Leave blank if tesseract is on PATH
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# CORS — frontend origin
FRONTEND_ORIGIN=http://localhost:5173
